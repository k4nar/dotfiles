// Zed settings
//
// For information on how to configure Zed, see the Zed
// documentation: https://zed.dev/docs/configuring-zed
//
// To see all of Zed's default settings without changing your
// custom settings, run `zed: open default settings` from the
// command palette (cmd-shift-p / ctrl-shift-p)
{
  "edit_predictions": {
    "provider": "copilot",
  },
  "agent": {
    "default_profile": "write",
    "default_model": {
      "provider": "copilot_chat",
      "model": "gpt-5.2",
      "enable_thinking": false,
    },
    "favorite_models": [],
    "model_parameters": [],
  },
  "git_panel": {
    "tree_view": true,
  },
  "diff_view_style": "unified",
  "agent_servers": {
    "claude-acp": {
      "type": "registry",
    },
  },
  "context_servers": {
    "mcp-server-context7": {
      "enabled": true,
      "remote": false,
      "settings": {},
    },
  },
  "which_key": {
    "delay_ms": null,
    "enabled": true,
  },
  "bottom_dock_layout": "contained",
  "title_bar": {
    "show_menus": false,
    "show_branch_icon": false,
  },
  "project_panel": {
    "hide_gitignore": true,
    "button": true,
  },
  "vim_mode": true,
  "terminal": {
    "font_size": 12.0,
    "font_family": "FiraMono Nerd Font",
    "copy_on_select": true,
    "max_scroll_history_lines": 100000,
  },
  "telemetry": {
    "diagnostics": true,
    "metrics": false,
  },
  "git": {
    "inline_blame": {
      "enabled": false,
    },
  },
  "base_keymap": "VSCode",
  "tab_bar": {
    "show": false,
  },
  "tabs": {
    "file_icons": false,
  },
  "use_smartcase_search": true,
  "sticky_scroll": {
    "enabled": true,
  },
  "vertical_scroll_margin": 5.0,
  "gutter": {
    "folds": false,
  },
  "minimap": {
    "show": "never",
    "thumb": "always",
  },
  "cursor_blink": false,
  "autosave": "on_focus_change",
  "buffer_font_family": "FiraCode Nerd Font",
  "file_types": {
    "jinja-html": ["*.html", "*.html"],
  },
  "show_whitespaces": "trailing",
  "icon_theme": {
    "mode": "dark",
    "light": "Zed (Default)",
    "dark": "Catppuccin Macchiato",
  },
  "ui_font_size": 14,
  "buffer_font_size": 12.0,
  "theme": "Bearded Theme Arc EolStorm",
}
