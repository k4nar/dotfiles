// Zed keymap
//
// For information on binding keys, see the Zed
// documentation: https://zed.dev/docs/key-bindings
//
// To see the default key bindings run `zed: open default keymap`
// from the command palette.
[
  {
    "context": "Workspace || Editor || Terminal",
    "bindings": {
      // Move between panes
      "shift-right": "workspace::ActivatePaneRight",
      "shift-left": "workspace::ActivatePaneLeft",
      "shift-up": "workspace::ActivatePaneUp",
      "shift-down": "workspace::ActivatePaneDown",
    },
  },
  {
    "context": "(Workspace || Editor) && !Terminal",
    "bindings": {
      // Terminal
      "shift-enter": "terminal_panel::Toggle",
    },
  },
  {
    "context": "Editor && vim_mode == insert",
    "bindings": {
      "shift-enter": "editor::NewlineBelow",
    },
  },
  {
    "context": "Editor && vim_mode == normal",
    "bindings": {
      // Files
      "space space": "file_finder::Toggle",
      "space s": "workspace::Save",

      // Terminal
      "shift-enter": "terminal_panel::Toggle",

      // Search
      // "space /": "pane::DeploySearch",
      "space /": [
        "task::Spawn",
        { "task_name": "Television search", "reveal_target": "center" },
      ],

      // Buffers
      "space l": "tab_switcher::ToggleAll",
      "space c": "pane::CloseActiveItem",
      "space C": "pane::CloseOtherItems",
      "space q": "pane::CloseAllItems",

      // Split
      "space |": "pane::SplitRight",
      "space -": "pane::SplitDown",

      // Navigation
      "space r": "pane::GoBack",
      "space i": "pane::GoForward",

      // Git
      "g a": "git::StageRange",
      "g u": "git::StageRange", // how to unstage?
      "g n": "editor::GoToNextChange",
      "g p": "editor::GoToPreviousChange",

      // Zed shortcuts
      "space p": "command_palette::Toggle",
      "space o": "project_symbols::Toggle", // how to use word under cursor?
      "space t": "project_symbols::Toggle",

      // Sneak (flask-like)
      "j": "vim::PushSneak",

      // substitute.nvim like replacement
      "s": "vim::PushReplaceWithRegister",
      "s s": ["workspace::SendKeystrokes", "g R r"],

      // LSP
      "space d": "editor::GoToDefinition",
      "space D": "editor::GoToTypeDefinition",
    },
  },
  {
    "context": "Editor && vim_mode == visual",
    "bindings": {
      // substitute.nvim like replacement
      "s": "vim::Paste",
    },
  },
  {
    "context": "MessageEditor",
    "bindings": {
      // Insert a newline instead of opening the terminal
      "shift-enter": "editor::Newline",
    },
  },
]
